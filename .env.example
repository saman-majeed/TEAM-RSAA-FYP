# Copy to ".env" in the project root and fill in values from:
# Firebase Console → Project settings → Your apps → Web app config

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — from the same web app snippet (for Google Analytics if you add getAnalytics later)
VITE_FIREBASE_MEASUREMENT_ID=

# Groq (question generation). Optional: VITE_GROQ_MODEL=llama-3.3-70b-versatile
VITE_GROQ_API_KEY=

# Candidate test links in email/copy use this URL when set (no trailing slash).
# If you create tests while on localhost but candidates open the app elsewhere, set this, e.g.:
#   http://192.168.1.10:5173   (another device on your LAN; run npm run dev with vite server.host — see vite.config.js)
#   https://your-site.web.app  (Firebase Hosting after deploy)
# If unset, links use whatever origin is in the browser when you click "Generate".
# VITE_PUBLIC_APP_URL=

# Proctoring: "inline" (default) = store JPEG data URLs on the result doc (no Storage billing; cap ~20 frames/doc for Firestore size).
# "storage" = upload to Firebase Storage (requires Auth → Sign-in method → Anonymous enabled, and storage rules deployed).
# VITE_PROCTORING_STORAGE=inline

# Optional: send candidate invites from the portal (no backend). https://www.emailjs.com — free tier.
# 1) Create Email Service (e.g. Gmail or Custom SMTP) + Email Template
# 2) In the template, set "To" email field to: {{to_email}}
# 3) Body: {{{message_html}}} and/or {{message}}, subject can use {{subject}}
# 4) IDs (same EmailJS account as Public Key):
#    - Public Key: Account → API keys
#    - SERVICE_ID: starts with service_  (Email Services → open your service)
#    - TEMPLATE_ID: starts with template_ (Email Templates → OPEN a template — ID is on that page; do not use the name)
#    Do not swap service_ and template_ in .env
# 5) Restart npm run dev after editing .env
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=